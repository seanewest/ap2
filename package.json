{
  "name": "after-party",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "api": "node dist-api/index.js",
    "build:api": "tsc -p tsconfig.api.json",
    "dev": "vite",
    "build": "tsc --noEmit && vite build && node scripts/build-docs.ts && npm run build:api",
    "check:rehearsal-status": "node scripts/check-rehearsal-status.ts",
    "report:codex": "node scripts/codex-session-report.ts",
    "test:e2e:cba": "playwright test --config playwright.cba.config.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:container": "node scripts/test-api-container.ts",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@azure/identity": "4.13.1",
    "@azure/msal-browser": "5.17.1",
    "jose": "6.2.4",
    "playwright": "1.61.1"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@types/node": "24.10.4",
    "jsdom": "29.1.1",
    "marked": "18.0.7",
    "typescript": "7.0.2",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  }
}
